# ---- MongoDB (only stores user accounts + credit balances, never uploaded data) ----
MONGO_URI=mongodb://localhost:27017
DB_NAME=prompt2data

# ---- Ollama Cloud (gpt-oss) ----
# Get a key at https://ollama.com  ->  Settings  ->  API Keys
OLLAMA_HOST=https://ollama.com
OLLAMA_API_KEY=your_ollama_cloud_api_key
OLLAMA_MODEL=gpt-oss:120b
# For local gpt-oss instead: OLLAMA_HOST=http://localhost:11434 (leave key blank, use gpt-oss:20b)

# ---- Optional tuning ----
CLEAN_CHUNK_SIZE=40
CREDITS_PER_10_ROWS=1
